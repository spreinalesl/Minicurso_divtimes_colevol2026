## Change character state numbers for text in Sastre Matrix
## Stipule shape
# 1. less than 6-7 pairs of cilia; 2. more than 6-7 pairs of unbranched cilia;
# 3. more than 6-7 pairs of branched cilia; 4. small scales; 5. large scales
dto_ed$stipule_shape_sastre[which(dto$stipule_shape_sastre == 1)] <- "unbranched cilia"
dto_ed$stipule_shape_sastre[which(dto$stipule_shape_sastre == 2)] <- "unbranched cilia"
dto_ed$stipule_shape_sastre[which(dto$stipule_shape_sastre == 3)] <- "branched cilia"
dto_ed$stipule_shape_sastre[which(dto$stipule_shape_sastre == 4)] <- "scales"
dto_ed$stipule_shape_sastre[which(dto$stipule_shape_sastre == 5)] <- "scales"
## terminal_inflorescence
# 1. yes; 2. no
dto_ed$terminal_inflorescence_sastre[which(dto$terminal_inflorescence_sastre == 1)] <- "yes"
dto_ed$terminal_inflorescence_sastre[which(dto$terminal_inflorescence_sastre == 2)] <- "no"
## Fused internal staminodes
# 1. yes; 2. no
dto_ed$fused_internal_staminodes_sastre[which(dto$fused_internal_staminodes_sastre == 1)] <- "yes"
dto_ed$fused_internal_staminodes_sastre[which(dto$fused_internal_staminodes_sastre == 2)] <- "no"
## Fused internal staminodes
# 1. yes; 2. no
dto_ed$fused_internal_staminodes_sastre[which(dto$fused_internal_staminodes_sastre == 1)] <- "yes"
dto_ed$fused_internal_staminodes_sastre[which(dto$fused_internal_staminodes_sastre == 2)] <- "no"
dfrom <- read.csv("~/Dropbox/Sandra/Manuscritos/divrates_landscape_heterog/ochnaceae/06_disperRsal/sauv_seedmorpho.csv")
dfrom2 <- read.csv("~/Dropbox/Sandra/Manuscritos/Lavradia/morphology/Sastre_1971_Recherche_sur_les_Ochnacees_morphomatrix.csv")
dto <- read.csv("~/Dropbox/Sandra/Manuscritos/Lavradia/morphology/Sauvagesia_morphdata_v4.csv")
######################################
## Merge with Sastre 1971 table
######################################
colnames(dfrom2) <- c("ID", "species", paste(colnames(dfrom2)[-c(1,2)], "sastre", sep = "_"))
dto_ed <- merge(dto, dfrom2, by = "species", all = T)
## Change character state numbers for text in Sastre Matrix
## Stipule shape
# 1. less than 6-7 pairs of cilia; 2. more than 6-7 pairs of unbranched cilia;
# 3. more than 6-7 pairs of branched cilia; 4. small scales; 5. large scales
dto_ed$stipule_shape_sastre[which(dto_ed$stipule_shape_sastre == 1)] <- "unbranched cilia"
dto_ed$stipule_shape_sastre[which(dto_ed$stipule_shape_sastre == 2)] <- "unbranched cilia"
dto_ed$stipule_shape_sastre[which(dto_ed$stipule_shape_sastre == 3)] <- "branched cilia"
dto_ed$stipule_shape_sastre[which(dto_ed$stipule_shape_sastre == 4)] <- "scales"
dto_ed$stipule_shape_sastre[which(dto_ed$stipule_shape_sastre == 5)] <- "scales"
## terminal_inflorescence
# 1. yes; 2. no
dto_ed$terminal_inflorescence_sastre[which(dto_ed$terminal_inflorescence_sastre == 1)] <- "yes"
dto_ed$terminal_inflorescence_sastre[which(dto_ed$terminal_inflorescence_sastre == 2)] <- "no"
## Fused internal staminodes
# 1. yes; 2. no
dto_ed$fused_internal_staminodes_sastre[which(dto_ed$fused_internal_staminodes_sastre == 1)] <- "yes"
dto_ed$fused_internal_staminodes_sastre[which(dto_ed$fused_internal_staminodes_sastre == 2)] <- "no"
## Fused internal staminodes
# 1. yes; 2. no
dto_ed$fused_internal_staminodes_sastre[which(dto_ed$fused_internal_staminodes_sastre == 1)] <- "yes"
dto_ed$fused_internal_staminodes_sastre[which(dto_ed$fused_internal_staminodes_sastre == 2)] <- "no"
## Placentation
# 1. parietal; 2. semi-basal; 3. basal
dto_ed$placentation_sastre[which(dto_ed$placentation_sastre == 1)] <- "parietal"
dto_ed$placentation_sastre[which(dto_ed$placentation_sastre == 2)] <- "semi-basal"
dto_ed$placentation_sastre[which(dto_ed$placentation_sastre == 1)] <- "basal"
## Suberized cells in the upper epidermis
# 1. yes; 2. no
dto_ed$suberized_cells_upepi_sastre[which(dto_ed$suberized_cells_upepi_sastre == 1)] <- "yes"
dto_ed$suberized_cells_upepi_sastre[which(dto_ed$suberized_cells_upepi_sastre == 2)] <- "no"
View(dto_ed)
View(dfrom2)
######################################
## Write table
######################################
write.csv(dto_ed, "~/Dropbox/Sandra/Manuscritos/Lavradia/morphology/Sauvagesia_morphdata_ed.csv",
row.names = F)
